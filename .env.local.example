# ─────────────────────────────────────────
# DESENVOLVIMENTO LOCAL
# ─────────────────────────────────────────
# O banco SQLite será criado automaticamente como "local.db"
DATABASE_URL=file:local.db

# ─────────────────────────────────────────
# PRODUÇÃO (Turso — SQLite na nuvem)
# Crie uma conta grátis em https://turso.tech
# Depois rode: turso db create williany18
#              turso db tokens create williany18
# ─────────────────────────────────────────
# DATABASE_URL=libsql://williany18-SEU_USUARIO.turso.io
# DATABASE_AUTH_TOKEN=SEU_TOKEN_AQUI

# ─────────────────────────────────────────
# SENHA DO PAINEL ADMIN
# ─────────────────────────────────────────
ADMIN_PASSWORD=
